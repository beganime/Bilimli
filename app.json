{
  "expo": {
    "name": "Bilimli",
    "slug": "bilimli",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beganime.bilimli"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#ffffff"
      },
      "package": "com.beganime.bilimli"
    },
    "web": {
      "favicon": "./assets/logo.jpg",
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "scheme": "bilimli"
  }
}
